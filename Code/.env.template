# ============================================================================
# PEAT — Environment Variables Template
# Copy to .env and fill in your keys:  cp .env.template .env
# ============================================================================

# HuggingFace token (needed for gated models: Gemma, Llama)
# Accepts either naming convention:
HF_KEY=
HF_Classic_Token=

# Google Cloud / Gemini API keys (4 keys for round-robin rate-limit handling)
GCP_KEY_1=
GCP_KEY_2=
GCP_KEY_3=
GCP_KEY_4=
# Alternative naming:
GCP_Key1=
GCP_Key2=
GCP_Key3=
GCP_Key4=

# DeepSeek API key (verified in dry-run but NOT auto-invoked as fallback)
DEEPSEEK_KEY=
Deepseek_API_key=
